# Variables de entorno sugeridas para despliegue RUPE.
# No guardar credenciales reales en Git ni compartir capturas con estos valores.

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Base de datos MySQL del alojamiento.
RUPE_DB_URL=jdbc:mysql://HOST:3306/rupe_db?useSSL=true&serverTimezone=America/Mexico_City
RUPE_DB_USER=usuario_aplicacion_rupe
RUPE_DB_PASSWORD=cambiar_por_password_seguro
RUPE_DDL_AUTO=validate
RUPE_SHOW_SQL=false

# Dominios publicados.
RUPE_ALLOWED_ORIGINS=https://tu-frontend-gratuito.example
RUPE_PUBLIC_BASE_URL=https://tu-frontend-gratuito.example

# Cloudflare Turnstile real.
RUPE_TURNSTILE_ENABLED=true
RUPE_TURNSTILE_SECRET=cambiar_por_secret_key_real

# Seguridad.
RUPE_EXPOSE_RESET_TOKEN=false
RUPE_COOKIE_SECURE=true
RUPE_COOKIE_SAME_SITE=none

# SMTP real para recuperacion de contrasena.
RUPE_MAIL_ENABLED=true
RUPE_MAIL_FROM=no-reply@tu-dominio.example
RUPE_MAIL_HOST=smtp.tu-proveedor.example
RUPE_MAIL_PORT=587
RUPE_MAIL_USERNAME=usuario_smtp
RUPE_MAIL_PASSWORD=password_smtp
RUPE_MAIL_SMTP_AUTH=true
RUPE_MAIL_SMTP_STARTTLS=true
